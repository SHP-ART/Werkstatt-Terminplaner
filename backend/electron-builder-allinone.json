{
  "appId": "com.example.werkstatt-terminplaner-complete",
  "productName": "Werkstatt Terminplaner",
  "directories": {
    "output": "dist-allinone"
  },
  "files": [
    "electron-main.js",
    "electron-preload.js",
    "status.html",
    "status.js",
    "src/",
    "database/",
    ".env"
  ],
  "extraResources": [
    {
      "from": "../frontend",
      "to": "frontend",
      "filter": [
        "**/*",
        "!node_modules/**",
        "!*.md"
      ]
    }
  ],
  "win": {
    "target": "portable",
    "icon": null
  }
}
